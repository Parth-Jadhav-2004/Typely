#!/bin/bash
# Typely launcher script
# This script activates the bundled virtual environment and runs the application

set -e

VENV_DIR="/usr/share/typely/.venv"
APP_DIR="/usr/share/typely"

# Check if venv exists, if not create it
if [ ! -d "$VENV_DIR" ]; then
    echo "First run: Setting up Typely environment..."
    python3 -m venv "$VENV_DIR"
    source "$VENV_DIR/bin/activate"
    pip install --upgrade pip setuptools wheel
    pip install -r "$APP_DIR/requirements.txt"
else
    source "$VENV_DIR/bin/activate"
fi

# Run the application in tray-only mode
cd "$APP_DIR" || exit 1
python3 -m typely "$@"
